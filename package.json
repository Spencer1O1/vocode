{
  "name": "vocode",
  "private": true,
  "packageManager": "pnpm@10.22.0",
  "description": "Root vocode monorepo",
  "scripts": {
    "build": "turbo run build",
    "fix": "pnpm lint:fix && go fmt ./...",
    "dev": "turbo run dev --parallel",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format .",
    "format:write": "biome format --write .",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "turbo": "^2.8.20"
  }
}
