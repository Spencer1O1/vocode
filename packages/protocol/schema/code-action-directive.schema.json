{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vocoding.net/schemas/code-action-directive.schema.json",
  "title": "CodeActionDirective",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "path": { "type": "string" },
    "range": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "startLine": { "type": "integer", "minimum": 0 },
        "startChar": { "type": "integer", "minimum": 0 },
        "endLine": { "type": "integer", "minimum": 0 },
        "endChar": { "type": "integer", "minimum": 0 }
      },
      "required": ["startLine", "startChar", "endLine", "endChar"]
    },
    "actionKind": {
      "type": "string",
      "enum": [
        "refactor.extract.function",
        "refactor.extract.variable",
        "refactor.extract.constant",
        "refactor.inline",
        "source.organizeImports",
        "source.fixAll",
        "quickfix"
      ]
    },
    "preferredTitleIncludes": { "type": "string" }
  },
  "required": ["path", "actionKind"]
}
