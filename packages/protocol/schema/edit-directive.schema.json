{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vocoding.net/schemas/edit-directive.schema.json",
  "title": "EditDirective",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "success" },
        "actions": {
          "type": "array",
          "items": { "$ref": "./edit-action.schema.json" }
        }
      },
      "required": ["kind", "actions"]
    },
    {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "noop" },
        "reason": { "type": "string" }
      },
      "required": ["kind", "reason"]
    }
  ]
}
