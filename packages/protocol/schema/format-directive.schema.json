{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vocoding.net/schemas/format-directive.schema.json",
  "title": "FormatDirective",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "path": { "type": "string" },
    "scope": { "type": "string", "enum": ["document", "selection"] },
    "range": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "startLine": { "type": "integer", "minimum": 0 },
        "startChar": { "type": "integer", "minimum": 0 },
        "endLine": { "type": "integer", "minimum": 0 },
        "endChar": { "type": "integer", "minimum": 0 }
      },
      "required": ["startLine", "startChar", "endLine", "endChar"]
    }
  },
  "required": ["path", "scope"]
}
